# === Обязательные переменные ===

# Токен бота MAX (получить в настройках бота на платформе партнёров MAX)
BOT_TOKEN=your_bot_token_here

# Порт, на котором запускается приложение
PORT=3000

# Публичный HTTPS URL приложения (например, https://your-app.up.railway.app)
# Нужен для регистрации webhook в MAX
PUBLIC_BASE_URL=https://your-app.example.com

# === Необязательные переменные (есть значения по умолчанию) ===

# Путь webhook-эндпоинта (по умолчанию: /webhook/max)
WEBHOOK_PATH=/webhook/max

# URL каталога продукции (по умолчанию: https://room-set.ru/virtualnyj-shourum/)
CATALOG_URL=https://room-set.ru/virtualnyj-shourum/

# Задержка перед отправкой второго сообщения в миллисекундах (по умолчанию: 1500)
# Допустимый диапазон: 1000–2000
SECOND_MESSAGE_DELAY_MS=1500

# Уровень логирования: fatal, error, warn, info, debug, trace (по умолчанию: info)
LOG_LEVEL=info

# Окружение: development, production (по умолчанию: production)
NODE_ENV=production

# === Тексты сообщений (необязательно — есть значения по умолчанию) ===

# Текст приветственного сообщения (первое сообщение)
# WELCOME_MESSAGE=...

# Текст сообщения с контактами (второе сообщение)
# CONTACTS_MESSAGE=...
